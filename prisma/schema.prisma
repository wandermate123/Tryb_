generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model OutboundLead {
  id               String   @id @default(cuid())
  firstName        String
  lastName         String
  companyName      String
  industry         String
  directEmail      String
  aiGeneratedPitch String   @db.Text
  status           String   @default("Sent")
  createdAt        DateTime @default(now())

  @@index([directEmail])
  @@index([createdAt])
}
