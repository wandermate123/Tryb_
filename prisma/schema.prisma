generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model OutboundLead {
  id               String   @id @default(cuid())
  /// Apollo person id — prevents duplicate rows on re-runs
  apolloPersonId   String?  @unique
  firstName        String
  lastName         String
  companyName      String
  industry         String
  /// Contact email when Apollo reveals it; null if not unlocked / not returned
  directEmail      String?
  /// Role / title of the person of contact when known (e.g. Founder, MD)
  jobTitle         String?
  /// Generic or corporate email for the company when Apollo returns one
  companyEmail     String?
  /// Primary domain for the company (from enrichment), useful if company email is empty
  companyDomain    String?
  linkedinUrl      String?
  instagramUrl     String?
  /// ICP: Skincare & Beauty | Food & Beverage | Boutique Hospitality
  nicheSegment     String?
  ///1–3 per Tryb SOP (Gemini heuristic; Instagram/Ads not automated)
  leadTier         String?
  /// Notes on opportunity / pipeline (auto-filled on create; you can edit in DB later)
  opportunity      String?  @db.Text
  aiGeneratedPitch String   @db.Text
  status           String   @default("Sent")
  repliedAt        DateTime?
  lastReplySnippet String?  @db.Text
  replyCount       Int      @default(0)
  createdAt        DateTime @default(now())
  replies          InboundReply[]

  @@index([createdAt])
  @@index([companyName])
}

model InboundReply {
  id             String       @id @default(cuid())
  outboundLeadId String?
  outboundLead   OutboundLead? @relation(fields: [outboundLeadId], references: [id], onDelete: SetNull)
  fromEmail      String
  toEmail        String?
  subject        String?
  textBody       String?      @db.Text
  htmlBody       String?      @db.Text
  messageId      String?
  rawPayload     Json?
  receivedAt     DateTime     @default(now())

  @@index([fromEmail])
  @@index([receivedAt])
}
