# Supabase — Project Settings → Database → URI (use Transaction pooler for serverless, e.g. port 6543)
# If your password contains @ # etc., URL-encode them (e.g. @ → %40)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Required for prisma db push / migrate. Prefer "Direct connection" from Supabase. If that host is unreachable (P1001), use "Session pooler" URI (port 5432, user postgres.[ref], host ...pooler.supabase.com).
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Optional — Supabase JS client (Auth / Storage / Realtime). NOT a substitute for DATABASE_URL.
# Project Settings → API → Project URL & anon key.
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Apollo.io — API Settings → REST API key
APOLLO_API_KEY=""
# Optional — one company keyword tag for People search (e.g. Cosmetics). Leave empty for broader results.
# APOLLO_INDUSTRY_KEYWORD_TAG=""
# Optional — pages per niche for api_search pagination (default 15 when unset).
# APOLLO_MAX_PAGES_PER_NICHE="15"
# Optional — relaxed ICP backfill pages when still short of OUTBOUND_MAX_CONTACTS_PER_RUN (default max(niche pages, 25)).
# APOLLO_MAX_PAGES_RELAXED="25"

# Google AI Studio — https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Resend — https://resend.com/api-keys (not used when OUTBOUND_SKIP_EMAIL_SEND=true)
RESEND_API_KEY=""

# Verified domain in Resend (not a real key)
RESEND_FROM="Tryb Studios <onboarding@resend.dev>"

# Set to true to skip Resend: only Apollo + Gemini + DB (sheet). Must be false for real sends.
# After Resend account/domain changes, rotate API key in dashboard if sends fail; trim spaces in RESEND_FROM.
OUTBOUND_SKIP_EMAIL_SEND="false"

# Optional — ms between Apollo enrich calls (default: 2000 if skip email, else 10000).
# OUTBOUND_PACE_MS="2000"

# Optional — max contacts processed per run after niche merge (default 50). SOP ~75/day needs multiple runs or lower pace + higher Vercel maxDuration.
# OUTBOUND_MAX_CONTACTS_PER_RUN="50"

# Optional: random string; same value on Vercel for secured cron
CRON_SECRET=""
